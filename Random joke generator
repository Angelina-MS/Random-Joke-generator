import requests

while True:
    answer=input("Would you like to generate a random joke?")
    if answer.lower().strip() in ["yes","yeah","yup","ok","sure","of course","yh","yuh","yhh"]:
        try:
            res= requests.get("https://official-joke-api.appspot.com/random_joke")
            data = res.json()
            print(data["setup"])
            print(data["punchline"])
            print()
        except:
            ("Sorry,could not get a joke right now.Please try again later!")
    else:
        print("Alright!Have a good day then")
